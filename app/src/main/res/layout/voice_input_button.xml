<?xml version="1.0" encoding="utf-8"?>
<!--
    Voice Input Button Layout Example

    Add this to your player creation form layout.
    Place it above or below your form fields.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Voice Input Button -->
    <Button
        android:id="@+id/microphoneButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🎤 Voice Input"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#4CAF50"
        android:drawableLeft="@drawable/ic_baseline_mic_24"
        android:drawablePadding="8dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:elevation="2dp"
        android:stateListAnimator="@null" />

    <!-- Helper Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap and say player details naturally"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-medium" />

    <!-- Optional: Progress Indicator (hidden by default) -->
    <ProgressBar
        android:id="@+id/voiceProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="8dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- Optional: Example Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Example: &quot;Mbappe, 91 overall, 93 potential, striker, 27 years old, France, 150M, 500K wage&quot;"
        android:textSize="11sp"
        android:textColor="@android:color/darker_gray"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:alpha="0.7" />

</LinearLayout>

