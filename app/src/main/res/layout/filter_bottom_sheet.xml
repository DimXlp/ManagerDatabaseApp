<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/flat_background_rounded">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filter and Sort"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:fontFamily="@font/chivo"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Sort Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sort By"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:fontFamily="@font/chivo"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/sort_radio_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/sort_none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="None (Default)"
            android:textColor="@android:color/black"
            android:fontFamily="@font/chivo"
            android:checked="true" />

        <RadioButton
            android:id="@+id/sort_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name (Last Name)"
            android:textColor="@android:color/black"
            android:fontFamily="@font/chivo" />

        <RadioButton
            android:id="@+id/sort_position"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Position"
            android:textColor="@android:color/black"
            android:fontFamily="@font/chivo" />

        <RadioButton
            android:id="@+id/sort_overall_asc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Overall (Ascending)"
            android:textColor="@android:color/black"
            android:fontFamily="@font/chivo" />

        <RadioButton
            android:id="@+id/sort_overall_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Overall (Descending)"
            android:textColor="@android:color/black"
            android:fontFamily="@font/chivo" />
    </RadioGroup>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/lighterGray"
        android:layout_marginVertical="16dp" />

    <!-- Filter by Position Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filter by Position"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:fontFamily="@font/chivo"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/position_filter_picker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="All Positions"
        android:textColor="@android:color/black"
        android:fontFamily="@font/chivo"
        android:padding="12dp"
        android:background="@drawable/flat_background_rounded"
        android:drawableEnd="@android:drawable/arrow_down_float"
        android:drawableTint="@android:color/black" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/lighterGray"
        android:layout_marginVertical="16dp" />

    <!-- Filter by Position Category Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filter by Position Category"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:fontFamily="@font/chivo"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/position_category_filter_picker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="All Categories"
        android:textColor="@android:color/black"
        android:fontFamily="@font/chivo"
        android:padding="12dp"
        android:background="@drawable/flat_background_rounded"
        android:drawableEnd="@android:drawable/arrow_down_float"
        android:drawableTint="@android:color/black" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center">

        <Button
            android:id="@+id/clear_filters_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Clear"
            android:textColor="@color/colorPrimary"
            android:background="@drawable/round_button"
            android:fontFamily="@font/chivo"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/apply_filters_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Apply"
            android:textColor="@color/colorPrimary"
            android:background="@drawable/round_button"
            android:fontFamily="@font/chivo"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>


