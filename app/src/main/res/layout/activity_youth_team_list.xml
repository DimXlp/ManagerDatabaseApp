<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".YouthTeamListActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/gradient_background">

        <include
            layout="@layout/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:animateLayoutChanges="true">

            <!-- Container for the entire top bar -->
            <FrameLayout
                android:id="@+id/top_bar_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/flat_background_rounded"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Search Icon at absolute far left edge - ALWAYS VISIBLE -->
                <ImageButton
                    android:id="@+id/search_icon_button"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@android:drawable/ic_menu_search"
                    android:backgroundTint="@color/colorAccent"
                    android:contentDescription="Search"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- Filter Icon at absolute far right edge - ALWAYS VISIBLE -->
                <ImageButton
                    android:id="@+id/filter_icon_button"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@android:drawable/ic_menu_sort_by_size"
                    android:backgroundTint="@color/colorAccent"
                    android:contentDescription="Filter and Sort"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- Year Navigation Container - Centered -->
                <LinearLayout
                    android:id="@+id/year_navigation_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center">

                    <Button
                        android:id="@+id/prev_year_button_ytp"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/ic_baseline_keyboard_arrow_left_24"
                        android:backgroundTint="@color/colorAccent" />

                    <LinearLayout
                        android:id="@+id/year_picker_container_ytp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:id="@+id/year_text_ytp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/chivo"
                            android:text="2020 / 21"
                            android:textColor="@color/colorAccent"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/year_player_count_ytp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="17 players"
                            android:textColor="#B3FFFFFF"
                            android:textSize="14sp"
                            android:fontFamily="@font/chivo"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/next_year_button_ytp"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/ic_baseline_keyboard_arrow_right_24"
                        android:backgroundTint="@color/colorAccent" />
                </LinearLayout>

                <!-- Sliding Search Bar (overlays year selector, stops before filter icon) -->
                <LinearLayout
                    android:id="@+id/search_bar_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:paddingStart="54dp"
                    android:paddingEnd="96dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:alpha="0">

                    <EditText
                        android:id="@+id/search_bar_ytp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Search players by name..."
                        android:padding="12dp"
                        android:background="@drawable/flat_background_rounded"
                        android:textColor="@color/colorAccent"
                        android:textColorHint="#80FFFFFF"
                        android:fontFamily="@font/chivo"
                        android:inputType="text"
                        android:maxLines="1"
                        android:imeOptions="actionSearch"
                        android:autofillHints="name" />
                </LinearLayout>

                <!-- Close/Cancel button - positioned between search bar and filter icon -->
                <ImageButton
                    android:id="@+id/close_search_button"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@android:drawable/ic_menu_close_clear_cancel"
                    android:backgroundTint="@color/colorAccent"
                    android:contentDescription="Close search"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="54dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    android:alpha="0" />
            </FrameLayout>

            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/lighterGray"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@+id/top_bar_container"/>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rec_view_ytp"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="16dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                app:layout_constraintTop_toBottomOf="@id/divider"
                app:layout_constraintBottom_toTopOf="@id/add_player_button_ytp"
                android:clipToPadding="false"
                android:paddingBottom="80dp" />

            <Button
                android:id="@+id/add_player_button_ytp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add Player"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:background="@drawable/round_button"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/chivo"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


        </androidx.constraintlayout.widget.ConstraintLayout>


    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nvView_ytp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        app:headerLayout="@layout/nav_header"
        android:layout_gravity="start"
        android:background="@android:color/white"
        app:itemIconTint="@color/colorAccent"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
