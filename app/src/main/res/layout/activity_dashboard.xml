<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Main content layout -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorPrimary"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Toolbar -->
            <include
                layout="@layout/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Manager Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/colorPrimaryDark"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEAD COACH"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"
                        android:textColor="@color/colorAccent"
                        android:fontFamily="@font/chivo"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/manager_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="@font/chivo"
                        android:layout_marginBottom="4dp"
                        tools:text="ALEXANDER VAUGHN" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/team_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorAccent"
                            android:fontFamily="@font/chivo"
                            android:letterSpacing="0.05"
                            android:drawableStart="@drawable/circle_shape"
                            android:drawablePadding="8dp"
                            tools:text="REAL MADRID CF" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Squad Highlights Grid -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SQUAD OVERVIEW"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="@color/white"
                android:fontFamily="@font/chivo"
                android:layout_marginBottom="12dp"
                android:paddingStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- First Team Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_first_team"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/colorPrimaryDark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="bottom">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="First Team"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="@font/chivo"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/first_team_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/colorAccent"
                            android:fontFamily="@font/chivo"
                            tools:text="22 Players"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Youth Team Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_youth_team"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/colorPrimaryDark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="bottom">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Youth Academy"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="@font/chivo"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/youth_team_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/colorAccent"
                            android:fontFamily="@font/chivo"
                            tools:text="5 Future Stars"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Recent Transfers Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RECENT TRANSFERS"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/white"
                    android:fontFamily="@font/chivo"
                    android:paddingStart="4dp"/>

                <TextView
                    android:id="@+id/view_all_transfers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textSize="11sp"
                    android:textColor="@color/colorAccent"
                    android:fontFamily="@font/chivo"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recent_transfers_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                tools:itemCount="2"
                tools:listitem="@layout/item_transfer_dashboard"/>

            <TextView
                android:id="@+id/no_transfers_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No recent transfers"
                android:textSize="14sp"
                android:textColor="@color/lighterGray"
                android:fontFamily="@font/chivo"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"/>

            <!-- Shortlist Quick View -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SHORTLIST"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/white"
                    android:fontFamily="@font/chivo"
                    android:paddingStart="4dp"/>

                <TextView
                    android:id="@+id/view_all_shortlist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View Hub"
                    android:textSize="11sp"
                    android:textColor="@color/colorAccent"
                    android:fontFamily="@font/chivo"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/colorPrimaryDark"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/shortlist_recycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_shortlist_dashboard"/>

                    <TextView
                        android:id="@+id/no_shortlist_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No players shortlisted"
                        android:textSize="14sp"
                        android:textColor="@color/lighterGray"
                        android:fontFamily="@font/chivo"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quick Actions Grid -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUICK ACTIONS"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="@color/white"
                android:fontFamily="@font/chivo"
                android:layout_marginBottom="12dp"
                android:paddingStart="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/quick_actions_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nvView_manage"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@android:color/white"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="@color/colorAccent"
        app:menu="@menu/drawer_menu" />
</androidx.drawerlayout.widget.DrawerLayout>


